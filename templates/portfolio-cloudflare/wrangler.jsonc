{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-portfolio-site",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "my-portfolio-site",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "my-portfolio-media",
		},
	]
	// Optional (paid plan): enable plugin sandboxing with Dynamic Worker Loader.
	// Uncomment this block only if your Cloudflare plan supports worker loaders.
	// "worker_loaders": [
	// 	{
	// 		"binding": "LOADER",
	// 	},
	// ],
}
